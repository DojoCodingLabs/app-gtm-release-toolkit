{
  "name": "@lapc506/flutter-go-to-market-toolkit",
  "version": "1.0.0",
  "description": "Launch your Flutter app to Google Play Store and Apple App Store in 24 hours — guided lifecycle with validation gates. OpenCode + Claude Code plugin.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": { "flutter-go-to-market-toolkit": "dist/cli.js" },
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./cli": { "import": "./dist/cli.js" }
  },
  "files": ["dist/", "commands/", "agents/", "skills/", "README.md", "LICENSE"],
  "engines": { "node": ">=20.11.0" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean && tsup src/cli.ts --format esm --clean false",
    "test": "echo 'no tests yet' && exit 0",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["opencode", "plugin", "flutter", "cicd", "go-to-market", "google-play", "app-store"],
  "repository": { "type": "git", "url": "git+https://github.com/lapc506/flutter-go-to-market-toolkit.git" },
  "author": "Luis Andres Pena Castillo",
  "license": "BSL-1.1",
  "dependencies": {
    "@opencode-ai/plugin": "^0.7.0",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  }
}
